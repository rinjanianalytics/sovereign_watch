# ============================================
# Sovereign Watch - Environment Configuration
# ============================================
# Copy this file to .env and customize values

# --- Location Center (All Services Use This) ---
# These coordinates define the monitoring region center
# Used by: adsb-poller, ais-poller, frontend map
CENTER_LAT=45.5152
CENTER_LON=-122.6784
COVERAGE_RADIUS_NM=150

# --- Tactical & System ---
# Interval for evicting stale aircraft arbitration entries (seconds)
ARBITRATION_CLEANUP_INTERVAL=30

# --- JS8Call Radio Terminal ---
# KiwiSDR source for headless JS8Call audio ingestion
KIWI_HOST=kiwisdr.example.com
KIWI_PORT=8073
KIWI_FREQ=14074
KIWI_MODE=usb
# Operator's Maidenhead locator (for distance/bearing)
MY_GRID=CN85

# --- API Keys ---
POSTGRES_PASSWORD=postgres
AISSTREAM_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# --- RF Pulse ---
# RepeaterBook (ham repeaters)
REPEATERBOOK_API_TOKEN=your_token_here
RF_RB_RADIUS_MI=200
RF_REPEATERBOOK_INTERVAL_H=6
# ARD (Amateur Repeater Directory - open source)
RF_ARD_INTERVAL_H=24
# NOAA NWR (Phase 2)
RF_NOAA_INTERVAL_H=168
# RadioReference (Public safety trunked systems)
RADIOREF_APP_KEY=your_token_here

# --- Frontend ---
# Set to false to force MapLibre fallback even if a token is present
VITE_ENABLE_MAPBOX=true
# Mapbox: Get from https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here
# Toggle 3D terrain/elevation (may impact performance)
VITE_ENABLE_3D_TERRAIN=false
